{
  "name": "dicy",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "check-dependencies": "rnx-align-deps",
    "fix-dependencies": "rnx-align-deps --write"
  },
  "eslintConfig": {
    "extends": [
      "@react-native",
      "plugin:testing-library/react-native"
    ]
  },
  "jest": {
    "preset": "react-native",
    "transformIgnorePatterns": [
      "/node_modules/(?!(react-native|@react-native|react-native-modal|react-native-animatable|react-native-vector-icons|@react-navigation)/)"
    ],
    "transform": {
      "^.+\\.(js|jsx|ts|tsx|mjs)$": "babel-jest"
    }
  },
  "dependencies": {
    "@babel/plugin-transform-nullish-coalescing-operator": "^7.26.6",
    "@babel/plugin-transform-optional-chaining": "^7.25.8",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "@typescript-eslint/utils": "^8.9.0",
    "i18next": "^25.0.1",
    "i18next-browser-languagedetector": "^8.0.0",
    "lottie-react-native": "^7.2.2",
    "react": "^19.0.0",
    "react-i18next": "^15.1.0",
    "react-native": "0.79.1",
    "react-native-image-crop-picker": "^0.42.0",
    "react-native-image-picker": "^8.2.0",
    "react-native-mmkv-storage": "^0.11.2",
    "react-native-modal": "^14.0.0-rc.1",
    "react-native-safe-area-context": "^5.4.0",
    "react-native-screens": "^4.4.0",
    "react-native-simple-dialogs": "^2.1.0",
    "react-native-vector-icons": "^10.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.25.3",
    "@babel/preset-typescript": "^7.25.9",
    "@babel/runtime": "^7.25.0",
    "@jest/globals": "^29.7.0",
    "@react-native-community/cli": "18.0.0",
    "@react-native-community/cli-platform-android": "18.0.0",
    "@react-native-community/cli-platform-ios": "18.0.0",
    "@react-native/babel-preset": "^0.79.1",
    "@react-native/eslint-config": "^0.79.1",
    "@react-native/metro-config": "^0.79.1",
    "@react-native/typescript-config": "^0.79.1",
    "@rnx-kit/align-deps": "^3.0.5",
    "@testing-library/react-native": "^13.2.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.0.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-test-renderer": "19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "babel-jest": "^29.6.3",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^9.25.1",
    "eslint-plugin-testing-library": "^7.1.1",
    "jest": "^29.2.1",
    "react-test-renderer": "19.0.0",
    "ts-jest": "^29.2.5",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "rnx-kit": {
    "kitType": "app",
    "alignDeps": {
      "requirements": [
        "react-native@0.79.1"
      ],
      "capabilities": [
        "babel-preset-react-native",
        "core",
        "core-android",
        "core-ios",
        "core/metro-config",
        "jest",
        "modal",
        "navigation/native",
        "react",
        "react-test-renderer",
        "safe-area",
        "screens"
      ]
    }
  }
}